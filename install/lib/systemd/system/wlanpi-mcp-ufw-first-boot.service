# wlanpi-mcp-ufw-first-boot.service

[Unit]
Description=wlanpi-mcp ufw first boot setup
After=network.target ufw.service wlanpi-first-boot.service
Before=wlanpi-mcp.service

[Service]
Type=oneshot
ExecStart=/etc/wlanpi-mcp/ufw/wlanpi-mcp-ufw-rules-setup.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
